#!/bin/sh
# Local gate: block commit subjects that won't parse as conventional commits.
# The changelog is generated from squash-merged subjects, so every commit
# subject must follow `type(scope)?: description`.
set -e

subject=$(head -n 1 "$1")

# Autosquash and merge/revert subjects are rewritten or generated by git.
case "$subject" in
  "fixup! "* | "squash! "* | "amend! "* | "Merge "* | "Revert \""*) exit 0 ;;
esac

types='feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert'
if ! printf '%s\n' "$subject" | grep -Eq "^($types)(\([a-z0-9._/-]+\))?!?: .+"; then
  echo "commit-msg: subject is not a conventional commit: $subject" >&2
  echo "  expected: type(scope)?: description, e.g. 'feat: add table catalog'" >&2
  echo "  types: $(printf '%s' "$types" | tr '|' ' ')" >&2
  exit 1
fi
