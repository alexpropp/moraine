# Workspace-root clangd config (editor-only; the cargo/CMake builds ignore it).
#
# clangd background-indexes and standalone-parses C++ under these paths, none
# of it first-party source we edit and none with a compile database clangd can
# use — so it emits hundreds of spurious diagnostics:
#   - duckdb/, extension-ci-tools/  : the build-toolchain submodules
#   - build/                        : the toolchain's DuckDB + extension build tree
#   - target/                       : cargo output and cached third-party checkouts
# This fragment suppresses every diagnostic under them; -ferror-limit=0 stops
# the one "too many errors" banner that Suppress cannot reach.
#
# PathMatch is a regex against the path relative to this file's directory, so
# it has no leading slash — `(.*/)?duckdb/.*`, not `.*/duckdb/.*`. The
# segment-boundary form keeps crates/moraine-duckdb (whose diagnostics we
# want) from matching.
If:
  PathMatch:
    - (.*/)?duckdb/.*
    - (.*/)?extension-ci-tools/.*
    - (.*/)?build/.*
    - (.*/)?target/.*
CompileFlags:
  Add: [-ferror-limit=0]
Diagnostics:
  Suppress: '*'
